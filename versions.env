# ---------------------------------------------------------------------------
# versions.env — Single source of truth for component versions.
#
# Loaded exactly once by the entry point of each execution path:
#   - hack/e2e/scripts/run-e2e-local.sh  (local / Makefile)
#   - .github/workflows/e2e.yaml         (CI)
#
# To override any version, either:
#   1. Edit this file, or
#   2. Export the variable before running the command, e.g.:
#        KAITO_VERSION=v0.10.0 make e2e-up
#   3. When triggering the GitHub Action manually, fill in the version inputs.
# ---------------------------------------------------------------------------

# Go toolchain version
GO_VERSION="1.26.1"

# KAITO workspace operator Helm chart version
KAITO_VERSION="v0.9.1"

# Istio version
ISTIO_VERSION="1.29.0"

# Gateway API CRD version
GATEWAY_API_VERSION="v1.2.0"

# BBR (Body-Based Router) release version
BBR_VERSION="v1.3.1"

# KEDA Helm chart version
KEDA_VERSION="v2.19.0"

# KEDA Kaito Scaler Helm chart version
KEDA_KAITO_SCALER_VERSION="v0.4.0"
